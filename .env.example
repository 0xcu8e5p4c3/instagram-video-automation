# ================================================
# Instagram Reels Auto-Upload Bot - Konfigurasi
# ================================================

# Instagram User ID (dapatkan dari Meta Developer Dashboard)
IG_USER_ID=your_instagram_user_id_here

# Access Token dari Instagram Graph API
# Pastikan token memiliki izin: instagram_content_publish, instagram_basic
ACCESS_TOKEN=your_access_token_here

# URL video yang akan diupload (harus URL publik yang dapat diakses)
# Contoh: https://example.com/videos/reels.mp4
VIDEO_URL=https://example.com/videos/your-reels-video.mp4

# Jadwal cron untuk upload otomatis (default: setiap hari jam 09:00 pagi)
# Format: detik menit jam hari bulan hari-minggu
# Contoh: "0 9 * * *" = setiap hari jam 09:00
CRON_SCHEDULE=0 9 * * *

# Timezone untuk cron scheduler
TIMEZONE=Asia/Jakarta

# Jumlah maksimal percobaan retry jika upload gagal
MAX_RETRY=3

# Delay antar retry dalam milidetik (default: 5000 = 5 detik)
RETRY_DELAY=5000

# Delay polling status container dalam milidetik (default: 10000 = 10 detik)
POLLING_INTERVAL=10000

# ================================================
# FORMAT CAPTION (dikustomisasi sesuai kebutuhan)
# ================================================

# Template teks caption — {day} akan diganti otomatis dengan nomor hari
CAPTION_TEMPLATE=for my self day {day}

# Hashtag yang selalu muncul di bawah caption (pisahkan dengan spasi)
CAPTION_TAGS=#everyday #daily


# Maksimal percobaan polling status (default: 12 = 2 menit total)
MAX_POLLING_ATTEMPTS=12
